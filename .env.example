# Payload
DATABASE_URI=postgres://payload:payload@localhost:5432/bkae
PAYLOAD_SECRET=__generate_with_openssl_rand_base64_32__
PREVIEW_SECRET=__rand__

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub
GITHUB_ORG=inference-club

# S3-compat storage (Supabase Storage or R2) — optional for local dev
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Supabase deployment (swap DATABASE_URI above):
# DATABASE_URI=postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
